# Azure AD / Entra ID — from your App Registration
# https://portal.azure.com → Azure Active Directory → App registrations
TENANT_ID="your-tenant-id"
APP_ID="your-app-client-id"
CLIENT_SECRET="your-client-secret"

# SharePoint Embedded — your Container Type ID
# Find this in the SPE admin center or via the SPE PowerShell module
CONTAINER_TYPE_ID="your-container-type-id"

# Server port (Azure Container Apps maps 80/443 → this port)
PORT=3000
